# Copy to .env and fill in real values. Never commit .env itself.

# SMTP for monitoring/emailer.py — if left blank, emailer falls back to console output
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=vendor-risk@example.com

# SQLite path (relative to repo root)
DATABASE_URL=sqlite:///./vendor_risk.db
