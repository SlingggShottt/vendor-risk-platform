# Copy to .env and fill in real values. Never commit .env itself.

# ── AI Contract Extraction ──────────────────────────────────────────────────
# Free API key at https://console.groq.com (no credit card needed)
# When unset, the /extract page runs in demo mode (no live AI call).
GROQ_API_KEY=

# ── Email Alerts — Resend (recommended, free at resend.com) ─────────────────
# Sign up at https://resend.com (GitHub login, no credit card).
# Without a verified domain, use the default sender onboarding@resend.dev
# and set ALERT_EMAIL_TO to the address you signed up with.
RESEND_API_KEY=re_your_key_here
ALERT_EMAIL_TO=you@youremail.com
# Optional: override the from address once you have a verified domain
# ALERT_EMAIL_FROM=Vendor Risk <alerts@yourdomain.com>

# ── Email Alerts — SMTP fallback (only used if RESEND_API_KEY is unset) ─────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
ALERT_EMAIL_FROM=vendorrisk@yourdomain.com

# ── Database (optional) ─────────────────────────────────────────────────────
# SQLite is used when seed_db.py is run; the platform works without it
# (CSV-first by default).
DATABASE_URL=sqlite:///vendor_risk.db
