# Copy to .env and fill in real values. Never commit .env itself.

# ── AI Contract Extraction ──────────────────────────────────────────────────
# Free API key at https://aistudio.google.com/apikey
# When unset, the /extract page runs in demo mode (no live AI call).
GEMINI_API_KEY=

# ── Email Alerts (SMTP) ─────────────────────────────────────────────────────
# All four vars must be set for real email to send; if any is missing the
# platform falls back to printing the email to the console (ConsoleBackend).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password

# Sender address shown in alert emails
ALERT_EMAIL_FROM=vendorrisk@yourdomain.com

# Comma-separated recipient(s) for all alert emails
ALERT_EMAIL_TO=security-team@yourdomain.com

# ── Database (optional) ─────────────────────────────────────────────────────
# SQLite is used when seed_db.py is run; the platform works without it
# (CSV-first by default).
DATABASE_URL=sqlite:///vendor_risk.db
